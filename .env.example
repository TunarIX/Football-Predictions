# Local-only example environment file.
# Copy to .env and fill API keys/local overrides for your shell.

# Virtual environment directory used by scripts/*.sh
VENV_DIR=.venv

# First football-data.co.uk season start year used by scripts/full_local_update.sh
START_YEAR=2018

# API-first upcoming fixtures and odds integration.
# The Odds API is the primary source for upcoming soccer fixtures, h2h odds,
# and totals odds. If unset, use the manual CSV fallback.
ODDS_API_KEY=

# Optional future/fallback provider for fixtures.
API_FOOTBALL_KEY=
